{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "player_webview",
    "torrent_engine"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    {
      "identifier": "fs:default",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "log:default",
    "player-commands"
  ]
}